venv/
__pycache__/
*.pyc

# ── All automation execution output goes into reports/ ──────────────────
# Run artifacts (timestamped sub-folders created by run_tests.py)
reports/*/
!reports/.gitkeep
# Report ZIPs and generated documents
reports/*.zip
reports/*.csv
reports/*.pdf
reports/*.docx

# Legacy output folders — no longer used; everything goes to reports/
output/
STC_Sanity_Automation/

# Invoice CSV downloads from E2E Step 17 — these are test run artifacts
billing/*.csv

# exports/ folder — generated inventory etc. (keep empty dir via .gitkeep)
exports/**
!exports/.gitkeep

# Stray Robot Framework files if robot is run directly from project root
output.xml
log.html
report.html
selenium-screenshot-*.png
pabot_results/
.pabotsuitenames

# Debug logs (generated at runtime by ReTriggerDebug / RuleEngineTab2)
*.log
debug-*.log

# Bug reports (generated by bug_reporter.py)
bugs/

# Config / secrets
.env
email_config.json

# Seed file (written at runtime by E2E flow for cross-suite variable sharing)
variables/.run_seed.json

# ── Helper scripts / generators (not part of test framework) ────────────
# One-time code generators (deleted from repo, ignore if recreated)
_gen_payg*.py


# Dev tools / scheduled run helpers
scheduled_run.py
check_results.py

# Backup files
tasks_backup.csv

# ── IDE / editor ────────────────────────────────────────────────────────
.cursor/
_temp_pulak/
.claude/
.vscode/
.idea/
*.swp
*.swo
*~
