# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  STC Automation — Environment Configuration
#  Copy this file to .env and fill in your values.
#  .env is gitignored and will NOT be committed.
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ── Email Report Settings (send_report.py) ──────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=your-email@gmail.com
EMAIL_TO=recipient1@airlinq.com,recipient2@airlinq.com

# ── Display Settings (used in email template) ──────────────
CLIENT=STC
ENV=QE

# ── Jira Bug Logger Settings (jira_bug_logger.py) ──────────
JIRA_BASE_URL=https://airlinq-global.atlassian.net
JIRA_EMAIL=your-email@airlinq.com
JIRA_API_TOKEN=your-api-token-here
JIRA_PROJECT_KEY=STC
JIRA_ISSUE_TYPE=Bug
